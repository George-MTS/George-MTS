<?xml version="1.0" encoding="utf-8"?>
<!-- FIX 2: WiFi section removed entirely. FIX 5: cellular-only summary card. -->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_medium">

            <!-- Permission banner -->
            <TextView
                android:id="@+id/permission_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/warning_red"
                android:padding="12dp"
                android:text="@string/permission_required"
                android:textColor="@color/white"
                android:visibility="gone"
                android:layout_marginBottom="@dimen/spacing_medium"/>

            <!-- Cellular data summary card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_medium"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Safaricom Cellular Data"
                            android:textColor="@color/secondary_text"
                            android:textSize="12sp"/>

                        <!-- FIX 2 + FIX 5: "since midnight" label, no WiFi mention -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cumulative since midnight"
                            android:textColor="@color/secondary_text"
                            android:textSize="10sp"/>

                    </LinearLayout>

                    <!-- Progress ring row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ProgressBar
                            android:id="@+id/circular_progress"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="@dimen/circular_progress_size"
                            android:layout_height="@dimen/circular_progress_size"
                            android:progressTint="@color/mint_green"
                            android:progressBackgroundTint="@color/primary_bg"
                            android:max="100"
                            android:progress="0"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/spacing_medium">

                            <TextView
                                android:id="@+id/tv_progress_percent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="@color/accent_gold"
                                android:textSize="28sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tv_threshold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="of Safaricom limit"
                                android:textColor="@color/secondary_text"
                                android:textSize="12sp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Cellular total — only field, WiFi removed -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/spacing_medium">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cellular used today"
                            android:textColor="@color/secondary_text"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tv_cellular_usage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 B"
                            android:textColor="@color/accent_gold"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                    <!-- FIX 5: updated every 30 seconds by DashboardViewModel periodic job -->
                    <TextView
                        android:id="@+id/tv_last_updated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Updating..."
                        android:textColor="@color/secondary_text"
                        android:textSize="10sp"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Section header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apps using cellular data"
                android:textColor="@color/primary_text"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_small"/>

            <!-- FIX 1: empty state shows "monitoring" message after reset -->
            <TextView
                android:id="@+id/empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/empty_state_message"
                android:textColor="@color/secondary_text"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_app_usage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </ScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
