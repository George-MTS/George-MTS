<?xml version="1.0" encoding="utf-8"?>
<!-- FIX 4 + FIX 6: single card per app. Active and Background are always visible as
     separate labelled lines. No WiFi references. Tap navigates to AppDetailFragment. -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/card_surface"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_app_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="App icon"/>

        <!-- App name + Active/Background lines -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary_text"
                android:textSize="14sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"/>

            <!-- FIX 4: Active (foreground cellular) — always visible, white text -->
            <TextView
                android:id="@+id/tv_active_usage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary_text"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>

            <!-- FIX 4: Background cellular — always visible, amber text -->
            <TextView
                android:id="@+id/tv_background_usage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_gold"
                android:textSize="11sp"
                android:layout_marginTop="1dp"/>

        </LinearLayout>

        <!-- Total cellular usage — right-aligned, prominent -->
        <TextView
            android:id="@+id/tv_total_usage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/mint_green"
            android:textSize="15sp"
            android:textStyle="bold"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
