# --- Telegram ---
# Create a bot with @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=

# --- Claude (Anthropic) ---
# LYRA's brain. Get a key from https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional override of the Claude model used for LYRA and all sub-agents.
CLAUDE_MODEL=claude-sonnet-4-6

# --- Supabase (memory layer) ---
# Project URL and anon key from your Supabase project settings.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- OpenAI (Whisper transcription for voice notes) ---
# Used to transcribe Telegram voice messages before they reach LYRA.
OPENAI_API_KEY=

# --- ElevenLabs (Phase 2 — voice replies) ---
# Leave blank until Phase 2. LYRA will reply in text only until this is set.
ELEVENLABS_API_KEY=

# --- Server ---
PORT=3000
